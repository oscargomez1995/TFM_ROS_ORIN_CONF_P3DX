<?xml version="1.0"?>

<robot name="pioneer3dx" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- import all gazebo-customization elements, including gazebo colors -->
  <xacro:include filename="$(find p3dx_description)/urdf/gz.xacro" />
  <!-- import the pioneer 3dx's wheels -->
  <xacro:include filename="$(find p3dx_description)/urdf/p3dx_wheel.xacro" />

  <!-- chassis -->
  <link name="base_link">
    <inertial>
      <mass value="3.5" />
      <origin xyz="-0.05 0 0" />
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1" />
    </inertial>
    <visual name="base_chassis_visual">
      <origin xyz="-0.045 0 0.148" rpy="0 0 0" />
      <geometry>
        <mesh filename="$(find p3dx_description)/meshes/chassis.stl" />
      </geometry>
      <material name="ChassisRed">
        <color rgba="0.851 0.0 0.0 1.0" />
      </material>
    </visual>
    <collision name="base_chassis_collision">
      <origin xyz="-0.045 0 0.145" rpy="0 0 0" />
      <geometry>
        <box size="0.35 0.25 0.14" />
      </geometry>
    </collision>
  </link>

  <!-- top_plate -->
  <link name="top_plate">
    <inertial>
      <mass value="0.01" />
      <origin xyz="0 0 0" />
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1" />
    </inertial>
    <visual name="top_plate_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="$(find p3dx_description)/meshes/top.stl" />
      </geometry>
      <material name="TopBlack">
        <color rgba="0.038 0.038 0.038 1.0" />
      </material>
    </visual>
    <collision name="top_plate_collision">
      <origin xyz="0.0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.45 0.38 0.01" />
      </geometry>
    </collision>
  </link>
  <joint name="base_top_joint" type="fixed">
    <origin xyz="-0.045 0 0.234" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="top_plate" />
  </joint>

  <!-- swivel -->
  <link name="swivel">
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01" />
    </inertial>
    <visual name="swivel_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="$(find p3dx_description)/meshes/swivel.stl" />
      </geometry>
      <material name="SwivelGrey">
        <color rgba="0.5 0.5 0.5 1" />
      </material>
    </visual>
    <collision name="swivel_collision">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.1 0.1" />
      </geometry>
    </collision>
  </link>
  <joint name="base_swivel_joint" type="continuous">
    <origin xyz="-0.185 0 0.055" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <parent link="base_link" />
    <child link="swivel" />
  </joint>

  <!-- center_hubcap -->
  <link name="center_hubcap">
    <inertial>
      <mass value="0.01" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.0124" ixy="0" ixz="0" iyy="0.0152" iyz="0" izz="0.0118" />
    </inertial>
    <visual name="center_hubcap_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="$(find p3dx_description)/meshes/center_hubcap.stl" />
      </geometry>
      <material name="HubcapGrey">
        <color rgba="0.5 0.5 0.5 1" />
      </material>
    </visual>
    <collision name="center_hubcap_collision">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.01" />
      </geometry>
    </collision>
  </link>
  <!-- <joint name="swivel_hubcap_joint" type="continuous">
    <origin xyz="-0.026 0 -0.016" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <parent link="swivel" />
    <child link="center_hubcap" />
  </joint> -->
  <joint name="base_hubcap_joint" type="continuous">
    <origin xyz="-0.0445 0 0.039" rpy="0 0 0" />
    <axis xyz="0 1 1" />
    <parent link="base_link" />
    <child link="center_hubcap" />
  </joint>

  <!-- center_wheel -->
  <link name="center_wheel">
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.0124" ixy="0" ixz="0" iyy="0.0152" iyz="0" izz="0.0118" />
    </inertial>
    <visual name="center_wheel_visual">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="$(find p3dx_description)/meshes/center_wheel.stl" />
      </geometry>
      <material name="WheelBlack">
        <color rgba="0.117 0.117 0.117 1" />
      </material>
    </visual>
    <collision name="center_wheel_collision">
      <origin xyz="0 0 0" rpy="${-3.1415927/2.0} 0 0" />
      <geometry>
        <cylinder radius="0.0375" length="0.01" />
      </geometry>
    </collision>
  </link>
  <joint name="center_wheel_joint" type="fixed">
    <origin xyz="-0.0035 0 -0.001" rpy="0 0 0" />
    <parent link="center_hubcap" />
    <child link="center_wheel" />
  </joint>

  <xacro:p3dx_wheel suffix="left" parent="base_link" reflect="1"/>
  <xacro:p3dx_wheel suffix="right" parent="base_link" reflect="-1"/>

  <!-- front_sonar -->
  <link name="front_sonar">
    <inertial>
      <mass value="0.0001" />
      <origin xyz="0 0 0" />
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1" />
    </inertial>
    <visual name="front_sonar_visual">
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="$(find p3dx_description)/meshes/front_sonar.stl" />
      </geometry>
      <material name="SonarYellow">
        <color rgba="0.715 0.583 0.210 1.0" />
      </material>
    </visual>
    <collision name="front_sonar_collision">
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <box size="0.02 0.02 0.02" />
      </geometry>
    </collision>
  </link>
  <joint name="base_front_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.109 0 0.145" />
    <parent link="base_link" />
    <child link="front_sonar" />
  </joint>

</robot>
